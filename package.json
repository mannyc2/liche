{
  "name": "lili",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Bun-native, LLM-friendly CLI core + build + releases monorepo.",
  "engines": {
    "bun": ">=1.3.0"
  },
  "workspaces": {
    "packages": ["packages/*"],
    "catalog": {
      "typescript": "latest",
      "zod": "^4.4.3",
      "@toon-format/toon": "^2.2.0",
      "tokenx": "^1.3.0",
      "yaml": "^2.9.0"
    },
    "catalogs": {
      "test": {
        "fast-check": "^4.8.0",
        "@stryker-mutator/core": "^9.6.1",
        "@stryker-mutator/typescript-checker": "^9.6.1",
        "@hughescr/stryker-bun-runner": "^1.2.2",
        "@types/bun": "latest"
      }
    }
  },
  "scripts": {
    "check": "bun run --filter '*' check",
    "test": "bun run --filter '*' test",
    "test:core": "bun run --filter @lili/core test"
  }
}
