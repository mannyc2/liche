    "@liche/build": "^0.7.0",
    "@liche/completions": "^0.7.0",
    "@liche/config": "^0.7.0",
    "@liche/core": "^0.7.0",
    "@liche/extensions": "^0.7.0",
    "@liche/mcp-installer": "^0.7.0",
    "@liche/mcp-server": "^0.7.0",
    "@liche/skills-installer": "^0.7.0",
    "@liche/skills-runtime": "^0.7.0",
    "@liche/telemetry": "^0.7.0",
    "@liche/tokens": "^0.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hughescr/stryker-bun-runner": "^1.2.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@stryker-mutator/core": "^9.6.1",
