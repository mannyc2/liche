{
  "name": "@liche/product",
  "version": "0.7.0",
  "type": "module",
  "license": "MIT",
  "description": "Product schema authoring, generated CLI surfaces, and conformance for Liche.",
  "repository": {
    "type": "git",
    "url": "https://github.com/mannyc2/liche.git",
    "directory": "packages/product"
  },
  "sideEffects": false,
