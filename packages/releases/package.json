{
  "name": "@liche/releases",
  "version": "0.8.1",
  "type": "module",
  "license": "MIT",
  "description": "Release manifests, package renderers, and publisher planning for Liche CLIs.",
  "repository": {
    "type": "git",
    "url": "https://github.com/mannyc2/liche.git",
    "directory": "packages/releases"
  },
  "sideEffects": false,
  "engines": {
    "bun": ">=1.3.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./manifest": {
      "types": "./src/manifest/schema.ts",
      "default": "./src/manifest/schema.ts"
    },
    "./binary": {
      "types": "./src/package/verify-binary.ts",
      "default": "./src/package/verify-binary.ts"
    },
    "./artifacts": {
      "types": "./src/package/verify-artifact.ts",
      "default": "./src/package/verify-artifact.ts"
    },
    "./package": {
      "types": "./src/package/index.ts",
      "default": "./src/package/index.ts"
    },
    "./yank": {
      "types": "./src/yank.ts",
      "default": "./src/yank.ts"
    },
    "./renderers": {
      "types": "./src/renderers/index.ts",
      "default": "./src/renderers/index.ts"
    },
    "./renderers/all": {
      "types": "./src/renderers/all.ts",
      "default": "./src/renderers/all.ts"
    },
    "./renderers/npm": {
      "types": "./src/renderers/npm.ts",
      "default": "./src/renderers/npm.ts"
    },
    "./renderers/pypi": {
      "types": "./src/renderers/pypi.ts",
      "default": "./src/renderers/pypi.ts"
    },
    "./renderers/homebrew": {
      "types": "./src/renderers/homebrew.ts",
      "default": "./src/renderers/homebrew.ts"
    },
    "./renderers/scoop": {
      "types": "./src/renderers/scoop.ts",
      "default": "./src/renderers/scoop.ts"
    },
    "./publishers": {
      "types": "./src/publishers/index.ts",
      "default": "./src/publishers/index.ts"
    }
  },
  "bin": {
    "liche-release": "src/cli.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@liche/core": "^0.8.1",
    "@liche/extensions": "^0.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
