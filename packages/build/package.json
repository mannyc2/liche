{
  "name": "@liche/build",
  "version": "0.8.0",
  "type": "module",
  "license": "MIT",
  "description": "Build and compile planning primitives for Bun-native Liche CLIs.",
  "repository": {
    "type": "git",
    "url": "https://github.com/mannyc2/liche.git",
    "directory": "packages/build"
  },
  "sideEffects": false,
  "engines": {
    "bun": ">=1.3.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "bin": {
    "liche-build": "src/cli.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "bun test",
    "mutate": "stryker run"
  },
  "dependencies": {
    "@liche/core": "^0.8.0",
    "@liche/extensions": "^0.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hughescr/stryker-bun-runner": "^1.2.2",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
