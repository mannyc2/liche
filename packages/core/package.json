{
  "name": "@lili/core",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "description": "Bun-native CLI runtime framework for Lili.",
  "sideEffects": false,
  "engines": {
    "bun": ">=1.3.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["src", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build src/index.ts --target=bun --format=esm --outdir=dist",
    "check": "tsc --noEmit",
    "test": "bun test",
    "test:contract": "bun test test/contract.test.ts",
    "test:golden": "bun test test/golden.test.ts",
    "test:property": "bun test test/property.test.ts --rerun-each=3 --randomize",
    "test:coverage": "bun test --coverage",
    "mutate": "stryker run"
  },
  "dependencies": {
    "tokenx": "^1.3.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hughescr/stryker-bun-runner": "^1.2.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/bun": "latest",
    "fast-check": "^4.8.0",
    "typescript": "latest"
  }
}
